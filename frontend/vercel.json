{
  "version": 2,
  "name": "inventory-management-system",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "@api_url",
    "VITE_APP_NAME": "InventoryPro"
  },
  "build": {
    "env": {
      "VITE_API_URL": "@api_url"
    }
  }
}
